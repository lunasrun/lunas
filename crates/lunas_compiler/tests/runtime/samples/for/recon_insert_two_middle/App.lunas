html:
    <div>
        <button class="go" @click="go()">go</button>
        <ul><li :for="item of items" :key="item.id">${item.label}</li></ul>
    </div>
script:
    let items = [{id:1,label:"a"},{id:2,label:"b"},{id:3,label:"c"}]
    function go(){ items = [items[0], {id:8,label:"m"}, {id:9,label:"n"}, items[1], items[2]] }
