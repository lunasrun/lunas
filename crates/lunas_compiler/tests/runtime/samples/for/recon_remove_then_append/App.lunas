html:
    <div>
        <button class="rm" @click="rm()">rm</button>
        <button class="ap" @click="ap()">ap</button>
        <ul><li :for="item of items" :key="item.id">${item.label}</li></ul>
    </div>
script:
    let items = [{id:1,label:"a"},{id:2,label:"b"},{id:3,label:"c"}]
    function rm(){ items = items.filter(i => i.id !== 2) }
    function ap(){ items.push({id:4,label:"d"}) }
