html:
    <div>
        <button class="go" @click="go()">go</button>
        <ul><li :for="grp of groups" :key="grp.id"><span :for="c of grp.items" :key="c" class="c">${c}</span></li></ul>
    </div>
script:
    let groups = [{id:1,items:[1,2]},{id:2,items:[3]}]
    function go(){ groups = [{id:1,items:[1,2,9]},{id:2,items:[3]}] }
