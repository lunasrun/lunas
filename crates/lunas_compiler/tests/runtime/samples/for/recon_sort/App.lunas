html:
    <div>
        <button class="go" @click="go()">go</button>
        <ul><li :for="item of items" :key="item.id">${item.label}</li></ul>
    </div>
script:
    let items = [{id:3,label:"c"},{id:1,label:"a"},{id:2,label:"b"}]
    function go(){ items = [...items].sort((x,y) => x.id - y.id) }
