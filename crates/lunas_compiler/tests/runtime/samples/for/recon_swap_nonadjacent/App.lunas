html:
    <div>
        <button class="go" @click="go()">go</button>
        <ul><li :for="item of items" :key="item.id">${item.label}</li></ul>
    </div>
script:
    let items = [{id:1,label:"a"},{id:2,label:"b"},{id:3,label:"c"},{id:4,label:"d"},{id:5,label:"e"}]
    function go(){ items = [items[4], items[1], items[2], items[3], items[0]] }
