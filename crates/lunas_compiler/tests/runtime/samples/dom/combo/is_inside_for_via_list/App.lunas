@use TextItem from "./TextItem.lunas"
@use NumberItem from "./NumberItem.lunas"
html:
    <div>
        <ul>
            <li :for="row of rows" :key="row.id">
                <component :is="row.kind === 'text' ? TextItem : NumberItem" :value="row.value"/>
            </li>
        </ul>
    </div>
script:
    let rows = [
        {id:1,kind:"text",value:"hello"},
        {id:2,kind:"number",value:"42"}
    ]
