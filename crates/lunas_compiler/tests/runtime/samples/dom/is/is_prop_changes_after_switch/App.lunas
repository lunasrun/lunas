@use Panel from "./Panel.lunas"
@use Notice from "./Notice.lunas"
html:
    <div>
        <component :is="view" :label="title"/>
        <button class="swap" @click="swap()">swap</button>
        <button class="rename" @click="rename()">rename</button>
    </div>
script:
    let view = Panel
    let title = "hi"
    function swap() { view = Notice }
    function rename() { title = "yo" }
